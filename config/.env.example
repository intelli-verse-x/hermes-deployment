# Hermes Agent — intelli-verse-x secrets template.
#
# Copy to .env (gitignored) and fill in. Most of these are already in our
# cluster — pull them with kubectl rather than re-minting.

# ─── Model gateway (LiteLLM) ────────────────────────────────────────────────
# Pull from the cluster:
#   kubectl get secret litellm-master-key -n aicart -o jsonpath='{.data.key}' \
#     | base64 -d
LITELLM_API_KEY=
# Hermes reads OPENAI_API_KEY as a fallback for "custom" providers; mirror
# the LiteLLM key into it so we don't have to teach Hermes about LiteLLM.
OPENAI_API_KEY=

# ─── Gas Town ───────────────────────────────────────────────────────────────
# Where the gastown TownRoot lives on this machine. The gt MCP server reads
# beads/rigs/mail from here.
GT_TOWN_ROOT=/Users/devashishbadlani/dev/gastown

# ─── n8n ────────────────────────────────────────────────────────────────────
# Pull from the cluster:
#   kubectl get secret n8n-admin -n aicart -o jsonpath='{.data.API_KEY}' \
#     | base64 -d
N8N_API_KEY=

# ─── Content Factory ────────────────────────────────────────────────────────
# In-cluster CF MCP endpoints (set when we deploy the CF MCP behind ingress).
CONTENT_FACTORY_MCP_URL=https://content-factory-mcp.intelli-verse-x.ai/mcp
CONTENT_FACTORY_MEDIA_MCP_URL=https://content-factory-media-mcp.intelli-verse-x.ai/mcp
CONTENT_FACTORY_MCP_TOKEN=

# ─── intelli-verse-x in-house ──────────────────────────────────────────────
INTELLI_VERSE_X_API_TOKEN=

# ─── Firecrawl ──────────────────────────────────────────────────────────────
# Get from https://firecrawl.dev/account or `firecrawl login --browser`.
FIRECRAWL_API_KEY=

# ─── Discord gateway ────────────────────────────────────────────────────────
# Use the SAME bot we already wired into n8n (DISCORD_BOT_TOKEN in n8n env).
# Pull from the n8n pod:
#   kubectl exec -n aicart deploy/n8n -- printenv DISCORD_BOT_TOKEN
DISCORD_BOT_TOKEN=

# Comma-separated list of Discord user IDs that may DM the bot. Anyone not
# on this list gets the "DM pairing" prompt instead of immediate access.
DISCORD_ALLOWED_USERS=

# ─── Telegram (optional) ────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=

# ─── Infisical (optional secret backend) ────────────────────────────────────
# Pull from cluster:
#   kubectl get secret infisical-admin -n aicart \
#     -o jsonpath='{.data.MACHINE_IDENTITY_TOKEN}' | base64 -d
# When set, the agent-vault skill (see docs/skill-routing.md) routes secret
# reads to Infisical instead of plain env.
INFISICAL_BASE_URL=https://infisical.intelli-verse-x.ai
INFISICAL_MACHINE_IDENTITY_TOKEN=

# ─── Langfuse (LLM observability) ───────────────────────────────────────────
# LiteLLM already forwards traces to Langfuse, so usually you don't need
# Hermes-specific keys. Set these only if you want a separate Hermes trace
# project that's distinct from the gastown one.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://langfuse.intelli-verse-x.ai
